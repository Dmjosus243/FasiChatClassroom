# Application Configuration
APP_NAME="FasiChat Classroom"
APP_ENV=development
APP_DEBUG=true
APP_URL="http://localhost/FasiChatClassroom"

# Database Configuration
DB_HOST=localhost
DB_NAME=fasichat
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Session Configuration
SESSION_NAME=fasichat_session
SESSION_LIFETIME=7200

# Upload Configuration
MAX_FILE_SIZE=10485760
MAX_AUDIO_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp3,wav,ogg,pdf,doc,docx,txt

# Security
CSRF_TOKEN_EXPIRY=3600